# --- Input / state ---
# Path templates may contain {group}, which is substituted per feed group at runtime.
FEEDS_FILE=data/feeds.json
STATE_FILE=data/seen_items/{group}.json

# --- Collector output sink ---
# jsonl | directory | stdout | slack
RAW_OUTPUT_TYPE=jsonl
RAW_OUTPUT_PATH=data/raw/{group}.jsonl

# --- Digest input (defaults to the collector's output) ---
# jsonl | directory
# RAW_INPUT_TYPE=jsonl
# RAW_INPUT_PATH=data/raw/{group}.jsonl

# --- Digest output sink ---
# markdown | html | stdout | slack | slack_canvas | slack_file | slack_pdf
# slack_file: uploads the HTML digest as a file attachment (Slack won't render
#             it inline — shows as a downloadable snippet).
# slack_pdf:  renders the HTML via headless Chromium (playwright) and uploads
#             as a PDF. Slack renders PDFs inline with pagination. Best fidelity.
DIGEST_OUTPUT_TYPE=markdown
DIGEST_OUTPUT_PATH=data/digests/{group}

# --- HTML sink styling (used when DIGEST_OUTPUT_TYPE=html) ---
DIGEST_CSS_FILE=templates/digest.css
# Optional cover banner — can be a URL or a local path. Local paths are
# base64-inlined into the HTML so the file stays self-contained.
# DIGEST_BANNER_URL=https://images.unsplash.com/photo-xxx?w=1200
# DIGEST_BANNER_URL=data/assets/banner.png

# --- Profile / interests ---
PROFILE_FILE=data/user_profile.md
INTERESTS_FILE=data/interests.json

# --- Poll cadence (used by `collect --loop`) ---
POLL_INTERVAL_MINUTES=30

# --- Slack (required only if any sink type above is `slack`) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Slack Canvas (required only if DIGEST_OUTPUT_TYPE=slack_canvas) ---
# Bot User OAuth Token (xoxb-...) with canvases:write + chat:write scopes.
# SLACK_BOT_TOKEN=xoxb-...
# Channel for the "new canvas posted" notification. Can be #channel-name or Cxxxx ID.
# The bot must be invited to this channel.
# SLACK_CANVAS_NOTIFY_CHANNEL=#ai-feed

# --- Summarizer ---
# stub | llm
SUMMARIZER=stub
# Shell command to pipe the prompt into. Must read stdin, print digest to stdout.
# Examples:
#   LLM_COMMAND=claude -p
#   LLM_COMMAND=llm -m claude-opus-4-7
#   LLM_COMMAND=ollama run llama3.1
# LLM_COMMAND=

# --- Digest tuning ---
MAX_ITEMS_FOR_DIGEST=40

# How many "runners up" items to list beneath the main narrative (0 to disable).
# HTML sink wraps this section in a collapsible <details>.
RUNNERS_UP_COUNT=12

# Drop items whose title+summary doesn't look like English before scoring.
# Uses a cheap unicode-range + stopword heuristic (no deps). Set to false to keep all.
FILTER_NON_ENGLISH=true

# --- Logging ---
LOG_LEVEL=INFO
