#!/bin/sh
# script/test — Run the test suite. (Smoke tests for now: import + CLI sanity.)
set -eu
cd "$(dirname "$0")/.."

if [ ! -d .venv ]; then
  echo "ERROR: .venv missing. Run script/setup first." >&2
  exit 1
fi

PY=.venv/bin/python

echo "==> Byte-compile"
$PY -m compileall -q contextizer main.py

echo "==> Module imports"
$PY -c "
from contextizer import config, logging_config, models
from contextizer.collector import feeds, normalize, state
from contextizer.digest import engine, profile, prompts, relevance, sources, summarizer
from contextizer.sinks import base, directory, html, jsonl, markdown, slack, slack_canvas, slack_file, slack_pdf, stdout
"

echo "==> CLI help"
$PY main.py --help > /dev/null
$PY main.py collect --help > /dev/null
$PY main.py digest --help > /dev/null
$PY main.py onboard --help > /dev/null

echo "==> Onboarding template prints"
$PY main.py onboard --print-template > /dev/null

echo "==> feeds.json parses cleanly"
$PY -c "
from pathlib import Path
from contextizer.config import load
from contextizer.collector.feeds import load_groups
cfg = load(Path('.'))
groups = load_groups(cfg.feeds_file)
assert groups, 'no groups loaded'
for name, g in groups.items():
    assert g.feeds, f'group {name!r} has no feeds'
    print(f'  group {name!r}: {len(g.feeds)} feeds')
"

echo "==> All checks passed"
