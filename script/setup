#!/bin/sh
# script/setup — Set up the project for first-time use.
set -eu
cd "$(dirname "$0")/.."

script/bootstrap

if [ ! -f .env ]; then
  echo "==> Creating .env from .env.example"
  cp .env.example .env
else
  echo "==> .env already present"
fi

for src in data/user_profile.md data/interests.json data/interests_frontend.json; do
  if [ ! -f "$src" ] && [ -f "$src.example" ]; then
    echo "==> Creating $src from $src.example"
    cp "$src.example" "$src"
  fi
done

echo "==> Setup complete"
echo "    Next: script/server                     (poll feeds continuously)"
echo "      or: .venv/bin/python main.py collect --once"
echo "      or: .venv/bin/python main.py digest --today --group ai"
